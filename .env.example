# ─── Required ───────────────────────────────────────────────────────────────

# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# Application URL (used for OAuth callbacks)
APP_URL=https://hirecommand.onrender.com

# Loxo ATS sync
LOXO_API_KEY=your_loxo_api_key_here

# ─── QuickBooks Integration ──────────────────────────────────────────────────
# Get these from: https://developer.intuit.com/app/developer/myapps
QB_CLIENT_ID=your_qb_client_id
QB_CLIENT_SECRET=your_qb_client_secret
QB_REDIRECT_URI=https://hirecommand.onrender.com/api/qb/callback

# ─── Optional / AI Features ──────────────────────────────────────────────────

# ProxyCurl — for live LinkedIn profile data in sync
# Get at: https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# Google Custom Search — for AI candidate sourcing
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# People Data Labs — for candidate enrichment
PDL_API_KEY=

# Anthropic — server-side proxy for AI Candidate Evaluation
ANTHROPIC_API_KEY=

# ─── Runtime (set by Render automatically) ───────────────────────────────────
NODE_ENV=production
PORT=10000
